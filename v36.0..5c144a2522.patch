+++ b/mythtv/libs/libmythtv/audio/audiooutputpulse.cpp
@@ -610,7 +610,15 @@ bool AudioOutputPulseAudio::ConnectPlaybackStream(void)
                                      (char*)"under");
     if (m_setInitialVol)
     {
-        int volume = gCoreContext->GetNumSetting("MasterMixerVolume", 80);
